# 环境变量配置
# 复制此文件为 .env 并修改为你自己的配置

# ============================================
# 域名配置
# ============================================
KEYCLOAK_HOSTNAME=keycloak.example.com
GRAFANA_HOSTNAME=grafana.example.com

# ============================================
# PostgreSQL (Keycloak)
# ============================================
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=changeme_strong_password_here

# ============================================
# Keycloak Admin
# ============================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_strong_admin_password

# ============================================
# Keycloak Realm & Client
# ============================================
KEYCLOAK_REALM=grafana
KEYCLOAK_CLIENT_ID=grafana
KEYCLOAK_CLIENT_SECRET=changeme_client_secret_here

# ============================================
# PostgreSQL (Grafana)
# ============================================
GRAFANA_DB=grafana
GRAFANA_DB_USER=grafana
GRAFANA_DB_PASSWORD=changeme_grafana_db_password

# ============================================
# Grafana Admin
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_admin_password
GRAFANA_ROOT_URL=https://grafana.example.com

# ============================================
# WebAuthn 配置 (可选)
# ============================================
# 启用 Passkey 自动填充
WEBAUTHN_ENABLE_PASSKEYS=true
# 用户验证要求: REQUIRED, PREFERRED, DISCOURAGED
WEBAUTHN_USER_VERIFICATION=REQUIRED
